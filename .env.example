# 이 파일을 복사해 .env.local을 만들고 실제 값을 채워주세요.
# cp .env.example .env.local

# 백엔드 API 베이스 URL
# 로컬 백엔드를 띄워 쓰는 경우: http://localhost:8080
# 운영 서버로 붙는 경우: https://api.bujirun.store
NEXT_PUBLIC_API_BASE_URL=https://api.bujirun.store

# 부지런-node (Yjs 실시간 협업 WebSocket 서버) 주소
# 로컬에서 bujirun-node를 직접 띄운 경우: ws://localhost:1234
# 운영/스테이징 주소는 아직 미확정 (인프라 담당에게 확인 필요)
NEXT_PUBLIC_YJS_WS_URL=ws://localhost:1234

# 카카오 로그인
NEXT_PUBLIC_KAKAO_CLIENT_ID=
NEXT_PUBLIC_KAKAO_REDIRECT_URI=http://localhost:3000/auth/kakao/callback

# 카카오맵 (카카오 디벨로퍼스 앱의 JavaScript 키 — 카카오톡 공유에도 동일한 키가 재사용됨)
# 카카오톡 공유를 쓰려면 콘솔에서 "카카오톡 공유" 활성화 + 플랫폼 > Web에 도메인 등록이 필요함
NEXT_PUBLIC_KAKAO_MAP_KEY=
